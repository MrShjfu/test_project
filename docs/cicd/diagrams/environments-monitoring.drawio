<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="helm-docs" version="24.0.0">
  <diagram id="env-topology" name="Environments &amp; Monitoring">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t2" value="Helm environments on Azure — Dev · SIT · Prod (one resource group per env, same Bicep, different params)" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="acr" value="Azure Container Registry (shared)&#10;helm-host:&lt;sha&gt; — same digest promoted Dev → SIT → Prod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="420" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="rgdev" value="rg-helm-dev  (auto deploy · scale-to-zero · 30d logs · + PR apps pr-&lt;id&gt;)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="480" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="devaca" value="ACA env + app&#10;helm-api-dev (0–2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">
          <mxGeometry x="15" y="40" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="devpg" value="Postgres Flexible B1ms&#10;(+ pr_&lt;id&gt; databases)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">
          <mxGeometry x="175" y="35" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="devsb" value="Service Bus&#10;helm-events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">
          <mxGeometry x="325" y="40" width="130" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="devswa" value="SWA ×3 (internal/portal/kiosk) + PR previews" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">
          <mxGeometry x="15" y="120" width="290" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="devkv" value="Key Vault + MI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">
          <mxGeometry x="325" y="120" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="devmon" value="Log Analytics + App Insights (dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="rgdev">
          <mxGeometry x="15" y="185" width="440" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="rgsit" value="rg-helm-sit  (auto after IntTests · 1–3 replicas · 30d logs)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="480" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="sitnote" value="Same shape as Dev:&#10;ACA app (1–3) · Postgres B1ms/B2s · Service Bus · SWA ×3 · Key Vault&#10;ASPNETCORE_ENVIRONMENT=Staging → dev-only features OFF&#10;Log Analytics + App Insights (sit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=8;" vertex="1" parent="rgsit">
          <mxGeometry x="15" y="40" width="440" height="185" as="geometry"/>
        </mxCell>
        <mxCell id="rgprod" value="rg-helm-prod  (manual approval · 2–10 replicas · HA Postgres · 90d logs)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="150" width="480" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="prodnote" value="ACA app 2–10, multiple-revision blue-green (old kept 24h)&#10;Postgres zone-redundant HA · Service Bus · SWA ×3 (staging slot swap)&#10;Key Vault + Managed Identity · availability test on /health&#10;Log Analytics + App Insights (prod) + full alert catalog (04)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=8;" vertex="1" parent="rgprod">
          <mxGeometry x="15" y="40" width="440" height="185" as="geometry"/>
        </mxCell>
        <mxCell id="alerts" value="Azure Monitor alert catalog (per env, as code): p95&gt;500ms · error&gt;1% · /health fail · outbox&gt;5min · DLQ&gt;0 · Hangfire failed · Postgres CPU/storage · AUDIT spike  →  Action group: email + Teams" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1520" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="cfg" value="Config layering (03): Bicep params (infra shape) → ACA app settings (non-secret) → Key Vault references (all secrets, via Managed Identity). Same image digest across envs — config never baked into images." style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="1200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="promote" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="rgdev" target="rgsit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p2" value="approval" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="rgsit" target="rgprod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="acr" target="rgdev"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

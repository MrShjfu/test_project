<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="helm-docs" version="24.0.0">
  <diagram id="fe-deploy-flow" name="FE Deploy Flow (pnpm)">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ft" value="FE deploy flow — 3 SPAs (internal / portal / kiosk) → Static Web Apps, package manager: pnpm" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="fci" value="CI (PR + main)&#10;corepack enable → pnpm install --frozen-lockfile&#10;pnpm nx affected -t lint,test,build (3 app + libs)&#10;Pipeline Caching: pnpm store + nx cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="360" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="fpr" value="PR opened → SWA preview environment&#10;built with VITE_API_BASE = pr-&lt;id&gt; API URL&#10;teardown on PR close" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="70" width="330" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="fnote" value="FE builds are per-env (VITE_API_BASE and App Insights key baked at build time) — unlike BE (image promote). Accepted: static builds are fast and always come from the same CI-verified commit sha." style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="820" y="70" width="700" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="flanedev" value="DEV (auto on merge to main)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="1520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="fd1" value="pnpm nx build ×3&#10;(env vars: dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanedev">
          <mxGeometry x="20" y="35" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fd2" value="SWA deploy task ×3&#10;(token from Key Vault)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanedev">
          <mxGeometry x="240" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fd3" value="smoke: GET / returns 200&#10;+ bundle points at the right API base" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanedev">
          <mxGeometry x="470" y="35" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="flanesit" value="SIT (auto after IntTests — same stage as BE SIT)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="1520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="fs1" value="pnpm nx build ×3 (env: sit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanesit">
          <mxGeometry x="20" y="35" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fs2" value="SWA deploy ×3 (sit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanesit">
          <mxGeometry x="240" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fs3" value="smoke + light e2e (Playwright smoke vs SIT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flanesit">
          <mxGeometry x="470" y="35" width="260" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="flaneprod" value="PROD (same approval gate as BE)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="1520" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="fp1" value="pnpm nx build ×3 (env: prod)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flaneprod">
          <mxGeometry x="20" y="40" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fp2" value="deploy to SWA&#10;STAGING environment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flaneprod">
          <mxGeometry x="240" y="40" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fp3" value="validate on the staging URL&#10;(smoke + login check)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flaneprod">
          <mxGeometry x="470" y="40" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fp4" value="SWAP staging → production&#10;(rollback = swap back)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="flaneprod">
          <mxGeometry x="710" y="40" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="fci" target="fpr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fe2" value="merge main" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="fci" target="flanedev"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fe3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="flanedev" target="flanesit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fe4" value="approval" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="flanesit" target="flaneprod"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

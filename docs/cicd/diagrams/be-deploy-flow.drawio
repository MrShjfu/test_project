<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="helm-docs" version="24.0.0">
  <diagram id="be-deploy-flow" name="BE Deploy Flow (Dev/SIT/Prod)">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bt" value="BE deploy flow — Helm.Host container through Dev / SIT / Prod (one image digest, promoted — never rebuilt)" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="bsrc" value="Merge → main&#10;CI green" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="130" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bpkg" value="Package&#10;ACR: helm-host:&lt;sha&gt;&#10;+ 12 EF migration bundles&#10;+ bicep artifact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="220" y="70" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="blanedev" value="DEV (auto)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="1520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="bd1" value="bicep what-if → apply&#10;(dev.bicepparam)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="20" y="35" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bd2" value="run migration bundles&#10;(12 schemas, pre-traffic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="240" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bd3" value="new ACA revision → 100%&#10;(single step in Dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="470" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bd4" value="smoke: /health 200&#10;+ 1 authorized round-trip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="700" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bd5" value="IntTests stage:&#10;integration + Playwright vs Dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="930" y="35" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bd6" value="App Insights&#10;release annotation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanedev">
          <mxGeometry x="1180" y="35" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="blanesit" value="SIT (auto after IntTests green)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="1520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="bs1" value="what-if → apply (sit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanesit">
          <mxGeometry x="20" y="35" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bs2" value="migration bundles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanesit">
          <mxGeometry x="240" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bs3" value="new ACA revision → 100%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanesit">
          <mxGeometry x="470" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bs4" value="smoke gate&#10;(fail = stop, Prod stays closed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blanesit">
          <mxGeometry x="700" y="35" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="blaneprod" value="PROD (manual approval on ADO Environment)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1520" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="bp0" value="APPROVAL&#10;(what-if diff attached)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blaneprod">
          <mxGeometry x="20" y="40" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="bp1" value="apply (prod) +&#10;migration bundles&#10;(backward-compatible, ADR-002)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blaneprod">
          <mxGeometry x="210" y="45" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bp2" value="new revision @ 0%&#10;smoke via revision URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blaneprod">
          <mxGeometry x="450" y="45" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bp3" value="traffic 10%&#10;metric gate (p95/error)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blaneprod">
          <mxGeometry x="670" y="45" width="170" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bp4" value="traffic 100%&#10;previous revision kept 24h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="blaneprod">
          <mxGeometry x="880" y="45" width="170" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bp5" value="ROLLBACK = az containerapp&#10;ingress traffic set (back to previous revision)&#10;schema is fix-forward only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="blaneprod">
          <mxGeometry x="1090" y="45" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="be1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="bsrc" target="bpkg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="be2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="bpkg" target="blanedev"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="be3" value="IntTests green" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="blanedev" target="blanesit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="be4" value="same image :sha" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="blanesit" target="blaneprod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="be5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="bp4" target="bp5"><mxGeometry relative="1" as="geometry"/></mxCell>

<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="helm-docs" version="24.0.0">
  <diagram id="db-config-flow" name="Database &amp; Config Flow">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="dbt" value="Database &amp; configuration — one Postgres server per env, one schema per module (ADR-002); config = code shape + Bicep params + Key Vault secrets" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="pg" value="PostgreSQL Flexible Server — helm-pg-&lt;env&gt;  (SKU/HA/retention from infra/params/&lt;env&gt;.bicepparam)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="640" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="score" value="schema: core&#10;companies · users&#10;owner: Helm.Core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="15" y="35" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="shang" value="schema: hangfire&#10;job storage&#10;owner: Helm.Core.Jobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="225" y="35" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sdbn" value="db: helm (single database)&#10;read-only cross-schema = FORBIDDEN&#10;cross-module refs = app-level ids" style="text;html=1;fontSize=10;fontColor=#666666;align=left;" vertex="1" parent="pg">
          <mxGeometry x="435" y="35" width="195" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="scrm" value="schema: crm&#10;customer · outbox · processed_events&#10;history: crm.__ef_migrations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="15" y="120" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="scpq" value="schema: cpq&#10;customer_ref · outbox · processed_events&#10;history: cpq.__ef_migrations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="270" y="120" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="smore" value="… ×8 more module schemas&#10;proposal_order · design · planning · inventory&#10;pre_processing · manufacturing · fulfilment · after_sales&#10;(each: outbox + processed_events + own history table)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="15" y="205" width="495" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="sprdb" value="db: pr_&lt;id&gt;&#10;(Dev server only)&#10;full schema set, migrate-from-zero&#10;dropped on PR close" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;align=left;spacingLeft=6;" vertex="1" parent="pg">
          <mxGeometry x="525" y="120" width="105" height="165" as="geometry"/>
        </mxCell>
        <mxCell id="app" value="Helm.Host on ACA (per env)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="70" width="380" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="appctx" value="ModuleDbContext&lt;T&gt; per module&#10;HasDefaultSchema(&quot;&lt;mod&gt;&quot;)&#10;company_id global filter + write guard&#10;OutboxModelBuilder.AddOutbox" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=6;" vertex="1" parent="app">
          <mxGeometry x="15" y="35" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="appcs" value="ConnectionStrings__Helm&#10;= Key Vault reference (Managed Identity)&#10;never in code / params / pipeline vars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=6;" vertex="1" parent="app">
          <mxGeometry x="15" y="125" width="350" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kv" value="Key Vault — helm-kv-&lt;env&gt;&#10;pg connection string (generated at provision)&#10;SB connection · SWA tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1180" y="70" width="330" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="mig" value="Migration flow (pipeline)&#10;Package: dotnet ef migrations bundle ×12&#10;(core + hangfire + 10 modules)&#10;Deploy&lt;Env&gt;: run bundles BEFORE traffic shift&#10;backward-compatible only (expand→contract, ADR-002)&#10;rollback = fix-forward schema, traffic-revert app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1180" y="180" width="330" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="cfg3" value="Config layering (03-deployment-config.md)&#10;1) Code = DB shape: schemas, tables, filters, history tables (per module DbContext)&#10;2) Bicep params = infra shape per env: SKU · replicas · HA · retention&#10;3) Key Vault = every secret, resolved at runtime via Managed Identity — no 4th path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="300" width="750" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lo" value="Local: docker compose postgres:17&#10;helm/helm@localhost:5432 (.env.example)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="330" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="te" value="Tests: Testcontainers postgres:17&#10;dynamic connection string — no static test config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="400" y="440" width="340 " height="60" as="geometry"/>
        </mxCell>
        <mxCell id="dr" value="Drift guard: weekly what-if per env → alert on diff (CICD-22) · portal edits = break-glass, codify within 48h" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="760" y="420" width="750" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="de1" value="reads/writes (scoped)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="app" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="de2" value="secret resolve (MI)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="appcs" target="kv"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="de3" value="bundles apply" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="mig" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

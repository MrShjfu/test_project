<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="helm-docs" version="24.0.0">
  <diagram id="database-config-flow" name="Database &amp; Config Flow">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1620" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n2" value="Database &amp; configuration — one Postgres server per env · one schema per module (ADR-002)" style="text;html=1;fontSize=16;align=left;fontColor=#555555;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1300" height="30" as="geometry" /></mxCell>
        <mxCell id="n3" value="PostgreSQL Flexible Server — helm-pg-&lt;env&gt;   (SKU / HA / retention from infra/params/&lt;env&gt;.bicepparam)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ededed;strokeColor=#bbbbbb;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="90" y="70" width="660" height="350" as="geometry" /></mxCell>
        <mxCell id="n4" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#107C10;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="58" y="230" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="n5" value="" style="sketch=0;aspect=fixed;html=1;points=[];align=center;fontSize=11;image;image=img/lib/azure2/databases/Azure_Database_PostgreSQL_Server.svg;labelBackgroundColor=none;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="n3"><mxGeometry x="15" y="40" width="52" height="52" as="geometry" /></mxCell>
        <mxCell id="n6" value="schema: core — companies · users (owner Helm.Core)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="n3"><mxGeometry x="90" y="45" width="300" height="32" as="geometry" /></mxCell>
        <mxCell id="n7" value="schema: hangfire — job storage" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="n3"><mxGeometry x="405" y="45" width="235" height="32" as="geometry" /></mxCell>
        <mxCell id="n8" value="schema: crm — customer · outbox · processed_events · crm.__ef_migrations" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="n3"><mxGeometry x="90" y="90" width="550" height="32" as="geometry" /></mxCell>
        <mxCell id="n9" value="schema: cpq — customer_ref · outbox · processed_events · cpq.__ef_migrations" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="n3"><mxGeometry x="90" y="130" width="550" height="32" as="geometry" /></mxCell>
        <mxCell id="n10" value="… ×8 module schemas (proposal_order · design · planning · inventory · pre_processing · manufacturing · fulfilment · after_sales) — each with outbox + processed_events + own history table" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="n3"><mxGeometry x="90" y="170" width="550" height="55" as="geometry" /></mxCell>
        <mxCell id="n11" value="db pr_&lt;id&gt; (Dev server only) — full schema set, migrate-from-zero, dropped on PR close" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;" vertex="1" parent="n3"><mxGeometry x="90" y="238" width="550" height="35" as="geometry" /></mxCell>
        <mxCell id="n12" value="cross-schema SQL forbidden · cross-module refs = app-level ids" style="text;html=1;fontSize=11;align=left;fontColor=#555555;" vertex="1" parent="n3"><mxGeometry x="90" y="285" width="540" height="25" as="geometry" /></mxCell>
        <mxCell id="n13" value="Helm.Host on ACA" style="sketch=0;aspect=fixed;html=1;points=[];align=center;fontSize=11;image;image=img/lib/azure2/containers/Container_Instances.svg;labelBackgroundColor=none;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="820" y="90" width="56" height="56" as="geometry" /></mxCell>
        <mxCell id="n14" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#107C10;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="795" y="88" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="n15" value="ModuleDbContext&lt;T&gt; per module: HasDefaultSchema · company_id filter + write guard · AddOutbox&#10;ConnectionStrings__Helm = Key Vault reference — never in code / params / pipeline vars" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="790" y="170" width="430" height="55" as="geometry" /></mxCell>
        <mxCell id="n16" value="Key Vault&#10;helm-kv-&lt;env&gt;" style="sketch=0;aspect=fixed;html=1;points=[];align=center;fontSize=11;image;image=img/lib/azure2/security/Key_Vaults.svg;labelBackgroundColor=none;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1300" y="90" width="56" height="56" as="geometry" /></mxCell>
        <mxCell id="n17" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#107C10;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1275" y="88" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="n18" value="pg connection string (generated at provision)&#10;SB connection · SWA tokens" style="text;html=1;fontSize=11;align=left;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="1260" y="170" width="320" height="40" as="geometry" /></mxCell>
        <mxCell id="n19" value="EF migration bundles ×12" style="sketch=0;aspect=fixed;html=1;points=[];align=center;fontSize=11;image;image=img/lib/azure2/devops/Azure_Artifacts.svg;labelBackgroundColor=none;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1300" y="260" width="56" height="56" as="geometry" /></mxCell>
        <mxCell id="n20" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#107C10;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1275" y="258" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="n21" value="run BEFORE traffic shift · expand→contract (ADR-002)&#10;rollback = fix-forward schema + traffic-revert app" style="text;html=1;fontSize=11;align=left;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="1260" y="340" width="340" height="40" as="geometry" /></mxCell>
        <mxCell id="n22" value="Config layering: 1) code = DB shape (schemas/tables/filters) · 2) Bicep params = infra shape per env · 3) Key Vault = every secret via Managed Identity — no 4th path" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="790" y="430" width="780" height="45" as="geometry" /></mxCell>
        <mxCell id="n23" value="Local: docker compose postgres:17 (helm/helm@localhost:5432)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="90" y="440" width="320" height="45" as="geometry" /></mxCell>
        <mxCell id="n24" value="Tests: Testcontainers postgres:17 — dynamic connection string" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="430" y="440" width="320" height="45" as="geometry" /></mxCell>
        <mxCell id="n25" value="Drift guard: weekly what-if per env → alert (CICD-22) · portal edits = break-glass, codify in 48h" style="text;html=1;fontSize=11;align=left;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="790" y="490" width="700" height="25" as="geometry" /></mxCell>
        <mxCell id="n26" value="reads/writes (scoped)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;strokeColor=#333333;" edge="1" parent="1" source="n13" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n27" value="secret resolve (MI)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;strokeColor=#333333;dashed=1;" edge="1" parent="1" source="n13" target="n16"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n28" value="bundles apply" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;strokeColor=#333333;dashed=1;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="n19" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>

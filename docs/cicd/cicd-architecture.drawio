          <mxGeometry x="1080" y="150" width="480" height="240" as="geometry" />
        </mxCell>
        <mxCell id="prodnote" value="ACA app 2–10, multiple-revision blue-green (old kept 24h)&#10;Postgres zone-redundant HA · Service Bus · SWA ×3 (staging slot swap)&#10;Key Vault + Managed Identity · availability test on /health&#10;Log Analytics + App Insights (prod) + full alert catalog (04)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=8;" vertex="1" parent="rgprod">
          <mxGeometry x="15" y="40" width="440" height="185" as="geometry" />
        </mxCell>
        <mxCell id="alerts" value="Azure Monitor alert catalog (per env, as code): p95&gt;500ms · error&gt;1% · /health fail · outbox&gt;5min · DLQ&gt;0 · Hangfire failed · Postgres CPU/storage · AUDIT spike  →  Action group: email + Teams" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1520" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cfg" value="Config layering (03): Bicep params (infra shape) → ACA app settings (non-secret) → Key Vault references (all secrets, via Managed Identity). Same image digest across envs — config never baked into images." style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">

        </mxCell>
        <mxCell id="rgsit" value="rg-helm-sit  (auto after IntTests · 1–3 replicas · 30d logs)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="480" height="240" as="geometry" />
        </mxCell>
        <mxCell id="sitnote" value="Same shape as Dev:&#10;ACA app (1–3) · Postgres B1ms/B2s · Service Bus · SWA ×3 · Key Vault&#10;ASPNETCORE_ENVIRONMENT=Staging → dev-only features OFF&#10;Log Analytics + App Insights (sit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;spacingLeft=8;" vertex="1" parent="rgsit">
          <mxGeometry x="15" y="40" width="440" height="185" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="main only" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="ci" target="pkg"><mxGeometry relative="1" as="geometry" /></mxCell>

          <mxGeometry x="15" y="120" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="devkv" value="Key Vault + MI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="rgdev">

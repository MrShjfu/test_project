          <mxGeometry x="500" y="100" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dev" value="Stage: DeployDev (auto)&#10;what-if → apply (dev)&#10;migration bundles&#10;ACA revision → 100%&#10;SWA deploy · smoke /health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="100" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="int" value="Stage: IntTests&#10;integration suite&#10;Playwright e2e vs Dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="170" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sit" value="Stage: DeploySIT (auto)&#10;same template, sit params&#10;smoke gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="100" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="approval" value="ADO Environment &quot;prod&quot;&#10;MANUAL APPROVAL&#10;(what-if diff attached)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1240" y="300" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="prod" value="Stage: DeployProd&#10;migration bundles&#10;ACA blue-green: new revision 0% → smoke → 10% → gate → 100%&#10;old revision kept 24h (rollback = traffic revert)&#10;SWA staging slot → swap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="360" height="120" as="geometry" />
        </mxCell>

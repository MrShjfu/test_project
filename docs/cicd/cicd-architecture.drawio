      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="Helm CI/CD — Azure Pipelines multi-stage (azure-pipelines.yml)" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="repo" value="Azure Repos&#10;main / PR&#10;(branch policies)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ci" value="Stage: CI  (PR + main)&#10;nx affected lint/test/build&#10;Testcontainers · NetArchTest&#10;Coverlet 60% · Sonar&#10;api-client drift · docker build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="230" y="100" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="pkg" value="Stage: Package (main)&#10;ACR push image :sha&#10;web bundles · bicep artifact&#10;EF migration bundles ×12" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dev" value="Stage: DeployDev (auto)&#10;what-if → apply (dev)&#10;migration bundles&#10;ACA revision → 100%&#10;SWA deploy · smoke /health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="100" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="int" value="Stage: IntTests&#10;integration suite&#10;Playwright e2e vs Dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="170" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sit" value="Stage: DeploySIT (auto)&#10;same template, sit params&#10;smoke gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="100" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="approval" value="ADO Environment &quot;prod&quot;&#10;MANUAL APPROVAL&#10;(what-if diff attached)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1240" y="300" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="prod" value="Stage: DeployProd&#10;migration bundles&#10;ACA blue-green: new revision 0% → smoke → 10% → gate → 100%&#10;old revision kept 24h (rollback = traffic revert)&#10;SWA staging slot → swap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="prenv" value="PR ephemeral env&#10;ACA pr-&lt;id&gt; + db pr_&lt;id&gt; (dev server)&#10;SWA preview → teardown on close" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="290" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oidc" value="Identity: workload identity federation (OIDC) service connections per env — no stored secrets · runtime secrets = Key Vault + Managed Identity (ADR-003)" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="900" height="30" as="geometry" />
        </mxCell>

          <mxGeometry x="230" y="290" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oidc" value="Identity: workload identity federation (OIDC) service connections per env — no stored secrets · runtime secrets = Key Vault + Managed Identity (ADR-003)" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">

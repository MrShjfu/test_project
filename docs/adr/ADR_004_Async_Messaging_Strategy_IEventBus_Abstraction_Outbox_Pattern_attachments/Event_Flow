flowchart TB
    APP["Application — PlaceOrder()<br/>BEGIN TX → insert proposal_order.orders<br/>+ insert proposal_order.outbox → COMMIT (atomic)"]
    OUTBOX[("proposal_order.outbox<br/>id · event_type · payload · created_at · processed_at")]
    RELAY["Outbox Relay (IHostedService) — every 1–5s<br/>SELECT … WHERE processed_at IS NULL<br/>FOR UPDATE SKIP LOCKED (multi-instance safe)<br/>publish via IEventBus → set processed_at"]
    BUS["IEventBus → RabbitMQ / Service Bus<br/>at-least-once delivery"]
    CONS["Consumer (e.g. Manufacturing)<br/>OnOrderPlaced: dedupe on event.id, then create job<br/>⚠ MUST BE IDEMPOTENT"]

    APP -->|event persisted in DB| OUTBOX
    OUTBOX -->|background poll| RELAY
    RELAY --> BUS
    BUS --> CONS

